APP_ENV=production
PORTAL_BASE_URL=https://blutenstein.com
WAITLIST_STORE=/data/waitlist.jsonl
CUSTOMER_DB=/data/customer_memory.sqlite3
# Set real values only on server; never commit secrets.

# AI Visibility Engine / Gemini (optional)
# Use one of these aliases; GEMINI_API_KEY is preferred.
GEMINI_API_KEY=
GEMINI_API=
GEMINI_KEY=
GOOGLE_API_KEY=
AI_VISIBILITY_GEMINI_API_KEY=
AI_VISIBILITY_GEMINI_MODEL=gemini-2.5-flash-lite

# Cloudflare AI / Edge stack (optional, secret values only on server)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
Cloudfaire_API=
Cloudfaire_API_TOKEN=
CLOUDFLARE_AI_GATEWAY_URL=
CF_AI_GATEWAY_URL=
CLOUDFLARE_AI_GATEWAY_NAME=
CLOUDFLARE_VECTORIZE_INDEX=
CF_VECTORIZE_INDEX=
CLOUDFLARE_AI_SEARCH_NAME=
CF_AI_SEARCH_NAME=
CLOUDFLARE_R2_BUCKET=
CF_R2_BUCKET=
CLOUDFLARE_WORKER_NAME=

# Telegram Bot API (owner/admin notification)
BlutensteinTelegrambot_API=
BlutensteinTelegram_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LINE Messaging API (owner/admin notification; LINE Notify retired 2025-03-31)
# Configure LINE Developers webhook URL: https://api.blutenstein.com/api/line/webhook
# After an admin/group messages the LINE bot, read /data/line_sources.jsonl and set LINE_MESSAGING_TO to source.userId/groupId/roomId.
BlutensteinL_INEChannel_secret=
Blutenstein_LINEChannel_access_token_long-lived=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
LINE_MESSAGING_TO=
LINE_USER_ID=
LINE_GROUP_ID=
LINE_ROOM_ID=

# Facebook / Meta Graph API for future Facebook order/message integrations.
Blutenstein_FB_TOKEN=
FACEBOOK_ACCESS_TOKEN=

# Customer reply email (optional, needed for direct email confirmation to users)
SMTP_HOST=
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
EMAIL_FROM=
